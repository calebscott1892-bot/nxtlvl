NXTLVL_ADMIN_KEY=replace-with-a-long-private-admin-key
DATABASE_URL=postgresql://replace-with-your-supabase-transaction-pooler-url

# Email booking alerts. Gmail requires an app password, not the normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Optional SMS booking alerts through Twilio.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
NOTIFY_PHONE=+19105079984
